# ─── Database ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# ─── AI / LLM ────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# ─── Qdrant Cloud Vector DB ───────────────────────────────────
QDRANT_URL=https://<cluster-id>.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=agentic_rag_v1

# ─── Cloudinary (File Storage) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Web Search ──────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret

# ─── Google OAuth (for Drive integration) ────────────────────
CLIENT_ID=your_google_oauth_client_id
CLIENT_SECRET=your_google_oauth_client_secret

# ─── Server ──────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Cloudinary (For persistent AI outputs) ──────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Debug (set to true in local dev only) ───────────────────
DEBUG_PARSING=false

# ─── Redis (Phase 2) ─────────────────────────────────────────
# Render: provision a free Redis instance, copy the Internal URL here
# Local dev: use redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Observability / LangSmith (Phase 10) ────────────────────
# Get free API key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=agentx-backend

# ─── Application (Phase 3 & 11) ──────────────────────────────
# Environment: "development" or "production"
APP_ENV=development
# Service name for structured logs
SERVICE_NAME=agentx-backend
SERVICE_VERSION=2.0.0

# ─── Rate Limiting (Phase 3) ─────────────────────────────────
# Max requests per minute per user for the chat/stream endpoint
CHAT_RATE_LIMIT=20
# Max requests per minute per user for the upload endpoint
UPLOAD_RATE_LIMIT=5

# --- CORS ----------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://agentx.ankitrajai.in

# ─── Workspace ───────────────────────────────────────────────
# Where agent-generated files (PDFs, DOCX, etc.) are stored
WORKSPACE_ROOT=/home/youruser/agentx_workspace
